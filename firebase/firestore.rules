rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) &&
        !request.resource.data.keys()
          .hasAny([
            'schemaVersion',
            'username',
            'usernameLower',
            'usernameChangeAvailableAt',
            'role',
            'accountType',
            'plan',
            'state',
            'birthState',
            'country',
            'addressChangeAvailableAt',
            'officialProfile',
            'photoURL',
            'photoPath',
            'photoVersion',
            'photoUpdatedAt',
            'photoChangeAvailableAt',
            'ref',
            'refCode',
            'referral',
            'points',
            'xp',
            'casualPoints',
            'rank',
            'seasonPoints',
            'seasonCategoryPoints',
            'stats',
            'badges'
          ]);
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny([
            'schemaVersion',
            'username',
            'usernameLower',
            'usernameChangeAvailableAt',
            'role',
            'accountType',
            'plan',
            'state',
            'birthState',
            'country',
            'addressChangeAvailableAt',
            'officialProfile',
            'photoURL',
            'photoPath',
            'photoVersion',
            'photoUpdatedAt',
            'photoChangeAvailableAt',
            'ref',
            'refCode',
            'referral',
            'points',
            'xp',
            'casualPoints',
            'rank',
            'seasonPoints',
            'seasonCategoryPoints',
            'stats',
            'badges'
          ]);
      allow delete: if false;
    }

    match /userPrivate/{userId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    function isValidHomepageSettings() {
      return request.resource.data.keys().hasOnly([
          'dailyHighlightBannerEnabled',
          'dailyHighlightBannerText',
          'dailyHighlightBannerEndDayKey',
          'updatedAt',
          'updatedBy'
        ]) &&
        request.resource.data.dailyHighlightBannerEnabled is bool &&
        request.resource.data.dailyHighlightBannerText is string &&
        request.resource.data.dailyHighlightBannerText.size() <= 160 &&
        request.resource.data.dailyHighlightBannerEndDayKey is string &&
        (
          request.resource.data.dailyHighlightBannerEndDayKey == '' ||
          request.resource.data.dailyHighlightBannerEndDayKey.matches('^\\d{4}-\\d{2}-\\d{2}$')
        ) &&
        request.resource.data.updatedBy == request.auth.uid;
    }

    match /platformSettings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() &&
        settingId == 'homepage' &&
        isValidHomepageSettings();
      allow delete: if false;
    }

    // Battles
    match /battles/{battleId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Battle Entries
    match /battleEntries/{entryId} {
      allow read: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Submissions
    match /submissions/{submissionId} {
      allow read: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /submissionReports/{reportId} {
      allow read: if isAdmin() || isOwner(resource.data.reporterId);
      allow create, update, delete: if false;
    }

    // Payments - never client-writable
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create, update, delete: if false;
    }

    // Battle Invites
    match /battleInvites/{inviteId} {
      allow read: if isAuthenticated() &&
        (resource.data.toUserId == request.auth.uid ||
         resource.data.fromUserId == request.auth.uid);
      allow create, update, delete: if false;
    }

    // Votes
    match /votes/{voteId} {
      allow read: if true;
      allow create: if false;
      allow update, delete: if false;
    }

    // Daily Highlights
    match /dailyHighlights/{dailyHighlightId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /dailyHighlightLikes/{likeId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /pointActivities/{activityId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /seasonRankings/{seasonId}/users/{userId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /qualifierRegistrations/{registrationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create, update, delete: if false;
    }

    match /qualifierParticipants/{participantId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /qualifierMatches/{matchId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /qualifierSubmissions/{submissionId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /qualifierVotes/{voteId} {
      allow read: if isOwner(resource.data.voterId) || isAdmin();
      allow create, update, delete: if false;
    }

    match /qualifierTracks/{trackId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Seasons
    match /seasons/{seasonId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // Championships
    match /championships/{championshipId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;

      match /stages/{stageId} {
        allow read: if true;
        allow create, update: if isAdmin();
        allow delete: if false;

        match /matches/{matchId} {
          allow read: if true;
          allow create, update: if isAdmin();
          allow delete: if false;
        }
      }
    }
  }
}
