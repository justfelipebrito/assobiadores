{
  "name": "batalha-de-assobio",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:admin": "turbo dev --filter=admin",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test && pnpm test:rules",
    "test:unit": "turbo test",
    "test:rules": "firebase emulators:exec --config firebase/firebase.json --only firestore --project demo-batalha \"vitest run firebase/firestore.rules.test.ts\"",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.4.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
