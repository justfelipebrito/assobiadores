{
  "name": "batalha-de-assobio",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:admin": "turbo dev --filter=admin",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test && pnpm test:rules",
    "test:unit": "turbo test",
    "test:rules": "pnpm exec firebase emulators:exec --config firebase/firebase.json --only firestore --project demo-batalha \"pnpm exec vitest run firebase/firestore.rules.test.ts\"",
    "validate:mp": "node scripts/validate-mercado-pago.cjs",
    "validate:mp:order": "node scripts/validate-mercado-pago.cjs --create-order",
    "emulators": "firebase emulators:start --config firebase/firebase.json --project demo-batalha",
    "seed:emulator": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8085 FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 pnpm --filter functions seed:emulator",
    "seed:qa:v1": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8085 FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 pnpm exec node firebase/functions/scripts/seed-v1-day-one.cjs",
    "seed:official-2026-catalog": "pnpm --filter functions seed:official-2026-catalog",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.0.0",
    "firebase-tools": "15.16.0",
    "prettier": "^3.3.0",
    "turbo": "^2.4.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  }
}
